import requests
import json

def detect_emotion(text_to_analyze):
    url = 'https://sn-watson-emotion.labs.skills.network/v1/watson.runtime.nlp.v1/NlpService/EmotionPredict'
    headers = {
        "grpc-metadata-mm-model-id": "emotion_aggregated-workflow_lang_en_stock",
        "Content-Type": "application/json"
    }
    input_json = {
        "raw_document": {
            "text": text_to_analyze
        }
    }

    response = requests.post(url, headers=headers, json=input_json)
    if response.status_code == 200:
        response_dict = json.loads(response.text)

        if "emotionPredictions" in response_dict:
            emotions = response_dict["emotionPredictions"][0]["emotion"]

            selected_emotions = {
                'anger': emotions.get('anger', 0),
                'disgust': emotions.get('disgust', 0),
                'fear': emotions.get('fear', 0),
                'joy': emotions.get('joy', 0),
                'sadness': emotions.get('sadness', 0)
            }

            dominant_emotion = max(selected_emotions, key=selected_emotions.get)

            output = selected_emotions
            output['dominant_emotion'] = dominant_emotion

            return output
        else:
            return {"error": "No emotion predictions found in response."}
    else:
        return {"error": f"Request failed with status code {response.status_code}"}

if __name__ == "__main__":
    user_text = input("Enter text to analyze emotion: ")
    result = detect_emotion(user_text)

    if "dominant_emotion" in result:
        print("Emotion scores:")
        for emotion, score in result.items():
            if emotion != "dominant_emotion":
                print(f"{emotion}: {score:.4f}")
        print(f"Dominant emotion: {result['dominant_emotion']}")
    else:
        print("Error or no emotions detected:", result)
